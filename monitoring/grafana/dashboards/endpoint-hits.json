{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "endpoint-hits",
  "title": "Endpoint Hits",
  "tags": ["portfolio", "endpoints"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 39,
  "panels": [
    {
      "title": "Total Hits per Endpoint",
      "description": "Total number of requests each endpoint has received",
      "type": "bargauge",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 100 },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum by (path) (http_requests_total)",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "title": "Hits per Endpoint Over Time",
      "description": "Rate of requests per endpoint over time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "mean", "max"] }
      },
      "targets": [
        {
          "expr": "sum by (path) (rate(http_requests_total[1m]))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "title": "Endpoint Hit Count Table",
      "description": "Detailed table of all endpoints with hit counts and methods",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "path" },
            "properties": [{ "id": "displayName", "value": "Endpoint" }]
          },
          {
            "matcher": { "id": "byName", "options": "method" },
            "properties": [{ "id": "displayName", "value": "Method" }]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "displayName", "value": "Total Hits" }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Total Hits", "desc": true }]
      },
      "transformations": [
        {
          "id": "reduce",
          "options": {
            "reducers": ["lastNotNull"]
          }
        }
      ],
      "targets": [
        {
          "expr": "sum by (method, path) (http_requests_total)",
          "legendFormat": "{{method}} {{path}}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "Hits by Method (GET vs POST)",
      "description": "Distribution of requests by HTTP method",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum by (method) (http_requests_total)",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "title": "Top Endpoints (Last 5 Minutes)",
      "description": "Most accessed endpoints in the last 5 minutes",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum by (path) (increase(http_requests_total[5m]))",
          "legendFormat": "{{path}}"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" }
}
